# Server-side AI provider used by /api/process-toc and /api/generate-board.
# Supported values: gemini, qwen, doubao, zhipu, custom
AI_PROVIDER=gemini

# Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Qwen / DashScope
DASHSCOPE_API_KEY=
QWEN_TEXT_MODEL=qwen-plus
QWEN_VISION_MODEL=qwen-vl-plus

# Zhipu
ZHIPU_API_KEY=
ZHIPU_TEXT_MODEL=glm-4-flash
ZHIPU_VISION_MODEL=glm-4v-flash

# Doubao / Volcengine Ark
DOUBAO_API_KEY=
DOUBAO_TEXT_MODEL=
DOUBAO_VISION_MODEL=

# Custom OpenAI-compatible provider
CUSTOM_PROVIDER_NAME=
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_TEXT_MODEL=
CUSTOM_VISION_MODEL=

# Required when using server-side built-in keys without a user-provided API key.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
